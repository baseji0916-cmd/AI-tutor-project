# Application settings — copy to .env and fill in values

APP_NAME=GrowthPilot
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./growthpilot.db

# Security (generate a strong secret for production)
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=90

# CORS (frontend dev server; add Render URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Allow *.vercel.app when frontend is on Vercel (default: true)
CORS_ALLOW_VERCEL=true
